{
  "name": "Analyze Repository",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "analyze",
        "options": {}
      },
      "id": "trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "operation": "create",
        "model": "Job",
        "data": {
          "repoUrl": "={{$json.repoUrl}}",
          "repoName": "={{$json.repoName}}",
          "owner": "={{$json.owner}}",
          "status": "RUNNING"
        }
      },
      "id": "prisma_create",
      "name": "Prisma Create Job",
      "type": "n8n-nodes-base.prisma",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "resource": "repository",
        "operation": "get",
        "owner": "={{$node[\"trigger\"].json[\"owner\"]}}",
        "repository": "={{$node[\"trigger\"].json[\"repoName\"]}}"
      },
      "id": "github_get",
      "name": "GitHub Get Repo",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [650, 300]
    },
    {
      "parameters": {
        "model": "gpt-4-turbo",
        "prompt": "Analyze this repository structure and provide architecture insights in JSON format matching the AnalysisResult type..."
      },
      "id": "openai_analyze",
      "name": "OpenAI Analyze",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [850, 300]
    },
    {
      "parameters": {
        "operation": "update",
        "model": "Job",
        "where": {
          "id": "={{$node[\"prisma_create\"].json[\"id\"]}}"
        },
        "data": {
          "status": "COMPLETED",
          "analysisResult": "={{$json.result}}"
        }
      },
      "id": "prisma_update",
      "name": "Prisma Update Job",
      "type": "n8n-nodes-base.prisma",
      "typeVersion": 1,
      "position": [1050, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{ "node": "Prisma Create Job", "type": "main", "index": 0 }]]
    },
    "Prisma Create Job": {
      "main": [[{ "node": "GitHub Get Repo", "type": "main", "index": 0 }]]
    },
    "GitHub Get Repo": {
      "main": [[{ "node": "OpenAI Analyze", "type": "main", "index": 0 }]]
    },
    "OpenAI Analyze": {
      "main": [[{ "node": "Prisma Update Job", "type": "main", "index": 0 }]]
    }
  }
}
